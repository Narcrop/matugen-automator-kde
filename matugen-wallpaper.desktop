[Desktop Entry]
Type=Service
MimeType=image/jpeg;image/png;image/webp;image/bmp;
Actions=setMatugenWallpaper;
X-KDE-Submenu=Personalización
X-KDE-ServiceTypes=KonqPopupMenu/Plugin

[Desktop Action setMatugenWallpaper]
Name=Establecer fondo con Matugen
Icon=background
# REEMPLAZA "tu_usuario" por tu nombre de usuario real de Linux:
Exec=bash /home/hugo/.local/bin/switch_rice.sh %f
